<tr><td>Support &amp; maintenance (15 %)</td><td>45–60 M</td><td>70–90 M</td><td>90–120 M</td></tr>
<tr><td>Licences</td><td>25–35 M</td><td>40–55 M</td><td>45–60 M</td></tr>
<tr><td>Équipe RUN DSI (4 ETP)</td><td>48 M</td><td>48 M</td><td>52 M</td></tr>
<tr><td><b>Total OPEX / an</b></td><td><b>203–253 M</b></td><td><b>278–343 M</b></td><td><b>327–412 M</b></td></tr>
</table>
<h2 style='font-size:14pt;color:#003366;margin:28px 0 12px;padding-bottom:6px;border-bottom:2px solid #003366'>7. Calendrier de décaissement (scénario Cible)</h2>
<table>
<tr><th>Trimestre</th><th>% cumulé</th><th>Montant cumulé (Md)</th><th>Jalons</th></tr>
<tr><td>T0–T1</td><td>15 %</td><td>0,5</td><td>Phase 0, marché signé</td></tr>
<tr><td>T2–T3</td><td>35 %</td><td>1,2</td><td>Alpha MVP</td></tr>
<tr><td>T4–T5</td><td>60 %</td><td>2,1</td><td>Go-live MVP M+12</td></tr>
