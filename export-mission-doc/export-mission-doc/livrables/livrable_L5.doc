<tr><td>RQ-02</td><td>Versement incomplet Data Room</td><td>3</td><td>4</td><td><b>12</b></td><td><b>Ouvert</b></td><td>Checklists A-F, relances formalisées, escalade</td><td>DPA</td></tr>
<tr><td>RQ-03</td><td>Accès données sensibles différé</td><td>2</td><td>3</td><td>6</td><td>Surveillé</td><td>Protocole DPO graduel</td><td>DPO</td></tr>
<tr><td>RQ-04</td><td>Délai 4 semaines accéléré</td><td>3</td><td>3</td><td>9</td><td>Maîtrisé</td><td>Agenda serré, 2 auditeurs</td><td>DM PORTIA</td></tr>
</table>
<div style='page-break-before:always;margin:0;padding:0'><br/></div>
