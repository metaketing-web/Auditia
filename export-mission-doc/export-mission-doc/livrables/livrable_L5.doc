<tr><td>RS-05</td><td>Connectivité régions</td><td>3</td><td>3</td><td>9</td><td>Surveillé</td><td>PWA offline (G-06)</td><td>DSI</td></tr>
<tr><td>RS-06</td><td>Dépendance prestataire unique</td><td>2</td><td>4</td><td>8</td><td>Surveillé</td><td>Transfert compétences</td><td>DSI</td></tr>
