<tr><td>R-OPE-02</td><td>Grille qualité data sur 10 sources</td><td>P0</td><td>DPSD</td></tr>
<tr><td>R-OPE-03</td><td>Pilote SSO sur 2 applications</td><td>P1</td><td>DSI</td></tr>
<tr><td>R-OPE-04</td><td>Procédure relances Data Room (cockpit)</td><td>P1</td><td>Secrétariat</td></tr>
