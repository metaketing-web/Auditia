<div style='page-break-before:always;margin:0;padding:0'><br/></div>
<h2 style='font-size:14pt;color:#003366;margin:28px 0 12px;padding-bottom:6px;border-bottom:2px solid #003366'>4. Recommandations priorisées</h2>
<h3 style='font-size:12pt;color:#333;margin:20px 0 8px'>4.1 Recommandations stratégiques (R-STR)</h3>
<table>
<tr><th>ID</th><th>Recommandation</th><th>Priorité</th><th>Horizon</th><th>Effort</th></tr>
<tr><td>R-STR-01</td><td>Adopter un MVP allégé (cf. L4 §5.1)</td><td>P0</td><td>Immédiat</td><td>Faible</td></tr>
<tr><td>R-STR-02</td><td>Créer une Cellule PNIPM (MOA + MOE + DPSD)</td><td>P0</td><td>M0</td><td>Moyen</td></tr>
<tr><td>R-STR-03</td><td>Arbitrer NNI comme clé bénéficiaire</td><td>P0</td><td>M0</td><td>Faible</td></tr>
<tr><td>R-STR-04</td><td>Lancer protocole accès NNI / SIGFIP</td><td>P0</td><td>M0–M3</td><td>Élevé</td></tr>
<tr><td>R-STR-05</td><td>Réviser CDC — retirer exigences caduc</td><td>P1</td><td>M1</td><td>Moyen</td></tr>
</table>
