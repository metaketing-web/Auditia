<tr><td>RS-01</td><td>Dérive périmètre CDC</td><td>3</td><td>4</td><td>12</td><td>Surveillé</td><td>Matrice L4, comité change</td><td>CT PNIPM</td></tr>
<tr><td>RS-02</td><td>Intégrateur sans expérience interop</td><td>2</td><td>4</td><td>8</td><td>Surveillé</td><td>Critères marché renforcés</td><td>DMP</td></tr>
<tr><td>RS-03</td><td>Surcharge DSI</td><td>4</td><td>3</td><td>12</td><td>Ouvert</td><td>Cellule projet dédiée</td><td>DSI</td></tr>
