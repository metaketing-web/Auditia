<table>
<tr><th>Livrable audit</th><th>Input marché</th></tr>
<tr><td>L2 Besoins</td><td>CCTP fonctionnel</td></tr>
<tr><td>L3 Carto</td><td>Architecture cible</td></tr>
<tr><td>L4 Matrice</td><td>Périmètre MVP</td></tr>
<tr><td>L5 Risques</td><td>Clauses contractuelles</td></tr>
