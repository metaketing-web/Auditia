<tr><td>Dispositifs / programmes</td><td>Partiel</td><td>2/5</td><td>DAJIP</td><td>P0</td></tr>
<tr><td>Territoires</td><td>Non harmonisé</td><td>2/5</td><td>DPSD</td><td>P1</td></tr>
