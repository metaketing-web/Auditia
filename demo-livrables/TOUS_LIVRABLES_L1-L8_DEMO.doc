<tr><td>Conduite du changement</td><td>90</td><td>120</td></tr>
<tr><td>MOE / recette / sécurité</td><td>80</td><td>110</td></tr>
<tr><td>Contingence 10 %</td><td>115</td><td>150</td></tr>
<tr><td><b>TOTAL</b></td><td><b>1 265</b></td><td><b>1 650</b></td></tr>
